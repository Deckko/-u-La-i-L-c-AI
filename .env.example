# ==================================
# SERVER ENVIRONMENT
# ==================================
PORT=3000

# ==================================
# DISCORD BOT CREDENTIALS
# ==================================
# (Lấy từ Discord Developer Portal)
DISCORD_TOKEN="YOUR_BOT_TOKEN_HERE"
DISCORD_CLIENT_ID="YOUR_APPLICATION_ID_HERE"
DISCORD_GUILD_ID="1511647892711018588"

# ==================================
# DATABASE CONFIGURATION
# ==================================
# Mongoose Connection String
MONGO_URI="mongodb+srv://username:password@cluster.mongodb.net/detong?retryWrites=true&w=majority"

# ==================================
# CACHE CONFIGURATION
# ==================================
# Dùng cho các cơ chế khóa (locking), in-memory updates
REDIS_URL="redis://localhost:6379"
